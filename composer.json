{
	"name": "hypejunction/site_search",
	"type": "elgg-plugin",
	"description": "Site search views and filters for Elgg",
	"homepage": "http://hypejunction.com",
	"keywords": [
		"elgg", "plugin", "search"
	],
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Ismayil Khayredinov",
			"email": "info@hypejunction.com"
		}
	],
	"require": {
		"php": ">=8.2",
		"elgg/elgg": "^5.0",
		"composer/installers": "^2.0",
		"hypejunction/object_sort": "~1.0",
		"hypejunction/user_sort": "~1.0",
		"hypejunction/group_sort": "~1.0"
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	},
	"extra": {
		"elgg-plugin": {
			"id": "site_search"
		}
	}
}
