{
	"name": "hypejunction/site_search",
	"type": "elgg-plugin",
	"description": "Site search views and filters for Elgg",
	"homepage": "https://github.com/hypeJunction/Elgg-site_search",
	"keywords": [
		"elgg",
		"plugin",
		"search"
	],
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Ismayil Khayredinov",
			"email": "ismayil.khayredinov@gmail.com"
		}
	],
	"require": {
		"composer/installers": "^2.0",
		"php": ">=8.1",
		"elgg/elgg": "~6.1.0",
		"ext-intl": "*",
		"hypejunction/object_sort": "~1.0",
		"hypejunction/user_sort": "~1.0",
		"hypejunction/group_sort": "~1.0"
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	},
	"extra": {
		"elgg-plugin": {
			"id": "site_search"
		}
	}
}
