<?xml version="1.0"?>
<ruleset name="site_search">
	<description>Coding standards for site_search plugin.</description>
	<rule ref="Elgg"/>
	<!-- Bundled legacy subplugins under mod/ are not part of this plugin's migration scope -->
	<exclude-pattern>*/mod/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
</ruleset>
